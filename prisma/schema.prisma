// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// npx prisma studio

// 1. Create migration
// ex: npx prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/12132023/migration.sql
// 2. Apply migration
// ex: npx prisma migrate resolve --applied 12132023
// 3. Push (skip to here if prototyping)
// ex: npx prisma db push && npm i

datasource db {
    provider     = "mysql"
    url          = env("DATABASE_URL")
    relationMode = "prisma"
}

generator client {
    provider = "prisma-client-js"
}

// ─── Multi-Tenancy ──────────────────────────────────────────────

model Organization {
    id        String   @id @default(cuid())
    name      String   @db.VarChar(255)
    slug      String   @unique @db.VarChar(100)
    createdAt DateTime @default(now())

    // Stripe billing (wired in Phase 5)
    stripeCustomerId   String? @unique
    subscriptionStatus String  @default("trialing") @db.VarChar(30)

    memberships     OrganizationMembership[]
    inventoryItems  InventoryItem[]
    categories      Category[]
    seasonPasses    SeasonPass[]
    patrons         Patron[]
    transactions    Transaction[]
    admissionEvents AdmissionEvent[]
    shifts          Shift[]
    feedbacks       Feedback[]
    hourCodes       HourCode[]
    timeclockEvents TimeClockEvent[]
    itemChangeLogs  ItemChangeLog[]
    savedReports    SavedReport[]
}

model OrganizationMembership {
    id             String       @id @default(cuid())
    organization   Organization @relation(fields: [organizationId], references: [id])
    organizationId String

    // Account identity
    userId      String? // Clerk userId — NULL for PIN-only accounts
    displayName String  @db.VarChar(255)
    pin         String? @db.VarChar(10)

    // Account type toggles (set on /users page)
    isPinOnly       Boolean @default(false) // true = no Clerk account, PIN identification only
    isSystemAccount Boolean @default(false) // true = shared kiosk login, requires PIN for auth features

    // Permission flags (extensible — add more toggles here over time)
    isAdmin Boolean @default(false)

    // Org-level role
    role String @default("staff") @db.VarChar(20) // owner / admin / staff

    createdAt DateTime @default(now())

    @@unique([organizationId, pin])
    @@unique([organizationId, userId])
    @@index([organizationId])
    @@index([userId])
}

// ─── Core Business Models ───────────────────────────────────────

model InventoryItem {
    id             String             @id @default(cuid())
    createdAt      DateTime           @default(now())
    createdBy      String
    organization   Organization?      @relation(fields: [organizationId], references: [id])
    organizationId String?
    label          String             @default("Unlabeled Inventory Item") @db.VarChar(255)
    sellingPrice   Int                @default(0)
    transactions   TransactionItems[]
    changeLogs     ItemChangeLog[]

    // concession items
    isConcessionItem Boolean @default(false)
    purchasePrice    Int?
    inStock          Int?    @default(0)
    category         String? @db.VarChar(100)

    // admission items
    isAdmissionItem Boolean  @default(false)
    isSeasonal      Boolean?
    isDay           Boolean?
    patronLimit     Int?

    @@index([organizationId])
}

model Category {
    id             String        @id @default(cuid())
    name           String        @unique @db.VarChar(100)
    createdAt      DateTime      @default(now())
    createdBy      String
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    @@index([organizationId])
}

model SeasonPass {
    id             String        @id @default(cuid())
    createdAt      DateTime      @default(now())
    createdBy      String
    patrons        Patron[]
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    label              String    @default("Unlabeled Season Pass") @db.VarChar(255)
    season             String    @default("2025") @db.VarChar(10)
    effectiveStartDate DateTime  @default(now())
    effectiveEndDate   DateTime?

    @@index([organizationId])
}

model Patron {
    id             String           @id @default(cuid())
    createdAt      DateTime         @default(now())
    createdBy      String
    pass           SeasonPass       @relation(fields: [passId], references: [id])
    passId         String
    admissions     AdmissionEvent[]
    organization   Organization?    @relation(fields: [organizationId], references: [id])
    organizationId String?

    firstName      String
    lastName       String
    birthDate      DateTime?
    banReEntryDate DateTime?

    @@index([passId])
    @@index([organizationId])
}

model Transaction {
    id             String             @id @default(cuid())
    createdAt      DateTime           @default(now())
    createdBy      String
    items          TransactionItems[]
    organization   Organization?      @relation(fields: [organizationId], references: [id])
    organizationId String?

    // Void tracking
    isVoided   Boolean   @default(false)
    voidedAt   DateTime?
    voidedBy   String?
    voidReason String?   @db.Text

    @@index([organizationId])
}

model TransactionItems {
    transaction   Transaction   @relation(fields: [transactionId], references: [id])
    transactionId String
    item          InventoryItem @relation(fields: [itemId], references: [id])
    itemId        String
    createdAt     DateTime      @default(now())
    createdBy     String
    amountSold    Int           @default(1)

    @@id([transactionId, itemId])
    @@index([transactionId])
    @@index([itemId])
}

model AdmissionEvent {
    id             String        @id @default(cuid())
    patronId       String
    patron         Patron        @relation(fields: [patronId], references: [id])
    createdAt      DateTime      @default(now())
    createdBy      String
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    // Void tracking
    isVoided   Boolean   @default(false)
    voidedAt   DateTime?
    voidedBy   String?
    voidReason String?   @db.Text

    @@index([patronId])
    @@index([organizationId])
}

// ─── Staff & Scheduling (deprecated features, kept for future) ──

model Shift {
    id             String        @id @default(cuid())
    userId         String
    start          DateTime
    end            DateTime
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    createdBy String
    createdAt DateTime @default(now())

    @@index([organizationId])
}

model Feedback {
    id             String        @id @default(cuid())
    message        String
    createdBy      String
    createdAt      DateTime      @default(now())
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    @@index([organizationId])
}

model HourCode {
    id              String           @id @default(cuid())
    label           String
    hourlyRate      Int
    timeclockEvents TimeClockEvent[]
    userSettings    UserSettings[]
    organization    Organization?    @relation(fields: [organizationId], references: [id])
    organizationId  String?

    createdBy String
    createdAt DateTime @default(now())

    @@index([organizationId])
}

model TimeClockEvent {
    id             String        @id @default(cuid())
    userId         String
    hourCodeId     String?
    hourCode       HourCode?     @relation(fields: [hourCodeId], references: [id])
    createdBy      String
    createdAt      DateTime      @default(now())
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    @@index([hourCodeId])
    @@index([organizationId])
}

// ─── User Settings (will be superseded by OrganizationMembership) ──

model UserSettings {
    id                String    @id @default(cuid())
    userId            String    @unique
    defaultHourCodeId String?
    defaultHourCode   HourCode? @relation(fields: [defaultHourCodeId], references: [id])
    canModifyHourCode Boolean   @default(false)
    clockPIN          String?   @unique
    isAdmin           Boolean   @default(false)
    canSchedule       Boolean   @default(false)

    createdBy String
    createdAt DateTime @default(now())

    @@index([defaultHourCodeId])
}

// ─── Audit & Reporting ──────────────────────────────────────────

model ItemChangeLog {
    id             String        @id @default(cuid())
    itemId         String
    item           InventoryItem @relation(fields: [itemId], references: [id])
    userId         String
    changeNote     String?       @db.Text
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    oldValues Json?
    newValues Json?

    createdAt DateTime @default(now())

    @@index([itemId])
    @@index([userId])
    @@index([organizationId])
}

model SavedReport {
    id             String        @id @default(cuid())
    name           String        @db.VarChar(100)
    reportType     String        @db.VarChar(30)
    datePreset     String?       @db.VarChar(30)
    customStart    DateTime?
    customEnd      DateTime?
    userId         String
    createdAt      DateTime      @default(now())
    organization   Organization? @relation(fields: [organizationId], references: [id])
    organizationId String?

    @@index([userId])
    @@index([organizationId])
}
